# ----------------------------------------------------------------------------
# Example local environment file for Spring Boot.
#
# How to use:
# 1) Copy this file to `.env`
# 2) Replace placeholder values with your local credentials
# 3) Never commit `.env` (it is ignored by `.gitignore`)
# ----------------------------------------------------------------------------

# Database connection used by `spring.datasource.*`
DB_URL=jdbc:postgresql://localhost:5432/reto-tecnico
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# Google OAuth2 credentials from Google Cloud Console
# Authorized redirect URI should include:
# http://localhost:8080/login/oauth2/code/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth2 credentials from Meta for Developers
# Valid OAuth Redirect URI should include:
# http://localhost:8080/login/oauth2/code/facebook
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret

# JWT signing configuration
# Use a long random base64-like value for local testing.
JWT_SECRET=your_long_jwt_secret
JWT_EXPIRATION_MS=86400000

